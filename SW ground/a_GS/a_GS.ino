// GSTU variables
// GSTU struct (Ground Station Telemetry Unit)
/*  
Two struct are used for the GSTU, a TX structure from the SCH to the ground station (GSTU_TX_data_str) designed to send telemetry data,
and a RX structure from the ground station to the SCH (GSTU_RX_data_str) to receive ground commands
  
Each one of the struct "cells" can contain a variable, the struct is defined with enough cells to host all the largest structs data.
For some of them, not all the available cells will be used, in such cases the unused cells contain the variable 0 or, 
if they have been already used to store another data, the last value used.
They won't be read whether the string corresponding to that specific identifier does't foresee information in that specific cell.
Apart from the "identifier" which is a "byte" variable, all the other cells are configured as "uint 16"
*/

typedef struct __attribute__((__packed__))
 {
 byte identifier = 0; // This first variable contains the header for the struct identification
 float  f_data_1 = 0; 
 float  f_data_2 = 0;
 float  f_data_3 = 0; 
 float  f_data_4 = 0;
 float  f_data_5 = 0;
 float  f_data_6 = 0;
 float  f_data_7 = 0; 
 float  f_data_8 = 0; 
 float  f_data_9 = 0;
 }

GSTU_RX_data_str;
GSTU_RX_data_str GSTU_RX_data_str_loc;  //Local data struct  
GSTU_RX_data_str GSTU_RX_data_str_rec;  //Remote (UART received) data struct

// Structure texture with adding the "point to point protocol", being this buffer used to store the data coming from the several peripheral units, 
// it must be sized to receive the largest struct used (GSTU_RX_data_str)
volatile uint8_t tx_buffer[sizeof(GSTU_RX_data_str) * 2];

// Variables for the checksum of the received structs
uint16_t GSTU_last_str_sum_FAP  = 0;
uint16_t GSTU_last_str_sum_ESP  = 0;
uint16_t GSTU_last_str_sum_EP  = 0;
uint32_t GSTU_last_str_sum_LP  = 0; // This is the only value requiring a 32 bit space to be stored due to the GNSS coordinates
uint32_t GSTU_str_sum = 0;


